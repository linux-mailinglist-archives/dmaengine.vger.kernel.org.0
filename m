>> > 		return IRQ_NONE;
>> > #endif
>> >
>> > 	dev_vdbg(idma64->dma.dev, "%s: status=%#x\n", __func__, status);
>> >
>> >
>> > I would like to see what's the difference in "working" wrt. I2C-HD messages
>> > above. If you can provide full dmesg again? Thanks!
>> 
